0 18 * * 0 /root/.claude/cc-run bash /Users/diamondpeakconsulting/diamondpeak-site/ClaudeCoach/scripts/weekly-plan.sh >> /root/Library/Logs/ClaudeCoach/weekly-plan.log 2>&1
